# InvBot V2 - Configuration
# Copy this file to .env and fill in your credentials

# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# ===========================================
# Database Configuration (REQUIRED)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=invbotv2_db
DB_USER=invbotv2_user
DB_PASSWORD=your_secure_database_password_here
DB_CONNECTION_LIMIT=20

# ===========================================
# Polymarket CLOB Integration
# ===========================================
POLYMARKET_API_BASE_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_PRIVATE_KEY=your_polymarket_private_key_here
POLYMARKET_PASSPHRASE=your_polymarket_passphrase_here

# ===========================================
# Wallet Configuration
# ===========================================
# Polygon Chain Wallet (256-bit hex key)
WALLET_PRIVATE_KEY=0xyour_ethereum_private_key_hex_here
WALLET_ADDRESS=0xyour_ethereum_address_here

# ===========================================
# Exchange APIs (Optional - for monitoring)
# ===========================================
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ===========================================
# Alternative Trading APIs (Optional)
# ===========================================
KALSHI_API_URL=https://trading-api.kalshi.com/v1
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY=

OPINION_API_URL=https://api.opiniontrade.com
OPINION_API_KEY=

PROBABLE_API_URL=https://api.0xprobable.com
PROBABLE_API_KEY=

# ===========================================
# Telegram Notifications (Optional)
# ===========================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===========================================
# Trading Parameters
# ===========================================
INITIAL_PORTFOLIO=10000
MAX_POSITION_SIZE=0.05

# Exchange APIs (for arbitrage monitoring)
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Kalshi API
KALSHI_API_URL=https://trading-api.kalshi.com/v1
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY=

# Opinion API
OPINION_API_URL=https://api.opiniontrade.com
OPINION_API_KEY=

# 0xProbable API
PROBABLE_API_URL=https://api.0xprobable.com
PROBABLE_API_KEY=

# Telegram Bot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Parameters
INITIAL_PORTFOLIO=10000
MAX_POSITION_SIZE=0.05
MIN_POSITION_SIZE=0.001
STOP_LOSS_PERCENT=10
TAKE_PROFIT_PERCENT=1.5

# Feature Flags
ENABLE_BETTING_FARM=true
ENABLE_ARBITRAGE=true
ENABLE_MICRO_TRADES=true
ENABLE_COPY_TRADING=true
REQUIRE_APPROVAL=true
