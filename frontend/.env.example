# InvBot V2 Frontend - Configuration
# Copy this file to .env.local and update values

# ===========================================
# API Configuration
# ===========================================
# Development
VITE_API_URL=http://localhost:3000/api/v1

# Production example
# VITE_API_URL=https://api.yourdomain.com/api/v1

# ===========================================
# Application Configuration
# ===========================================
VITE_APP_NAME=InvBot
VITE_APP_VERSION=2.0.0

# ===========================================
# Feature Flags
# ===========================================
VITE_ENABLE_TRADING=true
VITE_ENABLE_STRATEGIES=true
VITE_ENABLE_POLYMARKET=true
VITE_ENABLE_PORTFOLIO_EXPORT=true

# ===========================================
# Polymarket Configuration
# ===========================================
# Polygon Chain ID = 137
VITE_CHAIN_ID=137
VITE_CHAIN_NAME=Polygon
VITE_RPC_URL=https://polygon-rpc.com

# ===========================================
# UI Configuration
# ===========================================
VITE_THEME=light
VITE_LANGUAGE=en
